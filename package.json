{
	"name": "coub-addons",
	"description": "Coub.com additional features",
	"version": "0.1.29",
	"type": "module",
	"scripts": {
		"prepare": "lefthook install || true",
		"postinstall": "wxt prepare",
		"dev": "wxt",
		"dev:ff": "wxt -b firefox",
		"build": "wxt build",
		"build:ff": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:ff": "wxt zip -b firefox",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"bump": "node --disable-warning=ExperimentalWarning ./utils/bump.js",
		"test-build-reproducibility": "tsx ./utils/testBuildRepro.ts",
		"version": "run-s \"version:*\"",
		"version:gen-changelog": "git-cliff --bump -o",
		"version:gen-update-info": "node --disable-warning=ExperimentalWarning ./utils/genUpdateInfoHtml.js",
		"version:add-files": "git add CHANGELOG.md docs/release-notes",
		"release-build": "run-s \"release-build:*\"",
		"release-build:su-prod": "pnpm --filter=\"@coub-addons/segmenter-utils\" run postinstall",
		"release-build:zip-ff": "NODE_ENV=production wxt zip -b firefox",
		"add-update": "NODE_ENV=production node -r dotenv-flow/config ./utils/addUpdate.js",
		"release-notes": "node ./utils/genReleaseNotes.js",
		"gql:fetch-schema": "tsx -r dotenv-flow/config ./utils/fetchGqlSchema.ts",
		"gql:gen": "graphql-codegen --config ./utils/gqlCodegen.ts",
		"su": "pnpm --filter=\"@coub-addons/segmenter-utils\"",
		"pex": "pnpm --filter=\"@coub-addons/publish-extension\"",
		"wsi": "pnpm --filter=\"@coub-addons/wxt-svg-icon\"",
		"su:watch": "cargo bin cargo-watch -w packages/segmenter-utils/src -w packages/segmenter-utils/Cargo.toml -w packages/segmenter-utils/Taskfile.yml -w Cargo.lock -w Cargo.toml -w pnpm-lock.yaml -w rust-toolchain.toml -s \"pnpm su exec task build MODE=debug\""
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.19.0",
		"@codemirror/commands": "^6.9.0",
		"@codemirror/language": "^6.11.3",
		"@codemirror/lint": "^6.9.0",
		"@codemirror/search": "^6.5.11",
		"@codemirror/state": "^6.5.2",
		"@codemirror/view": "^6.38.5",
		"@coub-addons/segmenter-utils": "workspace:^",
		"@coub-addons/vite-plugin-arraybuffer": "workspace:^",
		"@coub-addons/wxt-svg-icon": "workspace:^",
		"@fluent/bundle": "^0.19.1",
		"@fluent/dom": "^0.10.2",
		"@fluent/langneg": "^0.7.0",
		"@fluent/react": "^0.15.2",
		"@fluent/sequence": "^0.8.0",
		"@heroicons/react": "^2.2.0",
		"@julr/vite-plugin-validate-env": "^2.2.0",
		"@lezer/generator": "^1.8.0",
		"@lezer/highlight": "^1.2.1",
		"@nextui-org/accordion": "^2.2.6",
		"@nextui-org/button": "^2.2.8",
		"@nextui-org/card": "^2.2.8",
		"@nextui-org/checkbox": "^2.3.7",
		"@nextui-org/chip": "^2.2.5",
		"@nextui-org/code": "^2.2.5",
		"@nextui-org/divider": "^2.2.5",
		"@nextui-org/input": "^2.4.7",
		"@nextui-org/kbd": "^2.2.5",
		"@nextui-org/link": "^2.2.6",
		"@nextui-org/modal": "^2.2.6",
		"@nextui-org/navbar": "^2.2.7",
		"@nextui-org/pagination": "^2.2.7",
		"@nextui-org/select": "^2.4.8",
		"@nextui-org/snippet": "^2.2.9",
		"@nextui-org/system": "^2.4.5",
		"@nextui-org/table": "^2.2.7",
		"@nextui-org/theme": "^2.4.4",
		"@nextui-org/tooltip": "^2.2.6",
		"@preact/preset-vite": "^2.10.2",
		"@preact/signals": "^2.3.2",
		"@react-types/shared": "3.26.0",
		"@types/chrome": "^0.1.24",
		"@types/i18n-js": "^3.8.9",
		"@types/jquery": "^1.10.45",
		"@types/moment": "2.11.29",
		"@types/node": "^22.18.9",
		"@uiw/codemirror-theme-aura": "^4.25.2",
		"base64-arraybuffer": "^1.0.2",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"dotenv-flow": "^4.1.0",
		"emoji-regex": "^10.5.0",
		"flexsearch": "^0.8.212",
		"framer-motion": "^12.23.24",
		"indent-string": "^5.0.0",
		"indexed-iterable": "^1.0.2",
		"itertools": "^2.5.0",
		"lightningcss": "^1.30.2",
		"nanoid": "^5.1.6",
		"npm-run-all2": "^8.0.4",
		"path-to-regexp": "^8.3.0",
		"postcss": "^8.5.6",
		"preact": "^10.27.2",
		"radix3": "^1.1.2",
		"react-helmet-async": "^2.0.5",
		"react-toastify": "^11.0.5",
		"sass-embedded": "^1.93.2",
		"superstruct": "^2.0.2",
		"tailwindcss": "^3.4.18",
		"thememirror": "^2.0.1",
		"type-fest": "^5.0.1",
		"typed-query-selector": "^2.12.0",
		"typescript": "^5.9.3",
		"use-debounce": "^10.0.6",
		"vite": "^6.3.6",
		"vite-plugin-sass-dts": "^1.3.34",
		"wouter-preact": "^3.7.1",
		"wxt": "^0.19.29"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@coub-addons/publish-extension": "workspace:^",
		"@cspell/dict-en-gb": "^5.0.14",
		"@cspell/dict-ru_ru": "^2.3.2",
		"@faker-js/faker": "^10.0.0",
		"@graphql-codegen/add": "^6.0.0",
		"@graphql-codegen/cli": "^6.0.0",
		"@graphql-codegen/typescript": "^5.0.2",
		"@graphql-codegen/typescript-operations": "^5.0.2",
		"@shikijs/cli": "^3.13.0",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"cspell": "^9.2.1",
		"dprint": "^0.50.2",
		"execa": "^9.6.0",
		"extract-zip": "^2.0.1",
		"git-cliff": "^2.10.1",
		"graphql": "^16.11.0",
		"graphql-config": "^5.1.5",
		"hast-util-to-html": "^9.0.5",
		"hastscript": "^9.0.1",
		"jszip": "^3.10.1",
		"lefthook": "^1.13.6",
		"listr2": "^9.0.4",
		"mdast-comment-marker": "^3.0.0",
		"mdast-util-from-markdown": "^2.0.2",
		"mdast-util-gfm": "^3.1.0",
		"mdast-util-to-hast": "^13.2.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-zone": "^6.1.0",
		"micromark-extension-gfm": "^3.0.0",
		"prettier": "^3.6.2",
		"rehype-minify-whitespace": "^6.0.2",
		"shiki": "^3.13.0",
		"tempy": "^3.1.0",
		"tsx": "^4.20.6",
		"unist-util-remove": "^4.0.0",
		"unist-util-visit": "^5.0.0",
		"vitest": "^3.2.4"
	},
	"pnpm": {
		"overrides": {
			"@types/node": "^22.18.9",
			"vite": "^6.3.6",
			"vite>jiti": ">=2"
		},
		"peerDependencyRules": {
			"ignoreMissing": [
				"react",
				"react-dom"
			]
		},
		"ignoredBuiltDependencies": [
			"dtrace-provider",
			"spawn-sync"
		],
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@go-task/cli",
			"@parcel/watcher",
			"dprint",
			"esbuild",
			"lefthook"
		],
		"patchedDependencies": {
			"git-cliff": "patches/git-cliff.patch"
		},
		"auditConfig": {
			"ignoreCves": [
				"CVE-2025-57319"
			]
		}
	},
	"packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
	"repository": "https://github.com/hikiko4ern/coub-addons.git",
	"author": "hikiko4ern",
	"license": "Unlicense",
	"private": true
}
