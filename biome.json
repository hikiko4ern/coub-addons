{
	"$schema": "https://biomejs.dev/schemas/2.2.5/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/*.json",
			"!**/*.css",
			"!**/*.scss",
			"!**/*.scss.d.ts",
			"!**/src/gql/**",
			"!**/docs/release-notes/**",
			"!**/packages/@nextui-org/**"
		]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"identifierOrder": "lexicographic",
						"groups": [
							":NODE:",
							":PACKAGE:",
							":BLANK_LINE:",
							"@/**",
							":BLANK_LINE:",
							[":PATH:", "!./*.{css,scss}"],
							":BLANK_LINE:",
							"./*.{css,scss}"
						]
					}
				}
			}
		}
	},
	"formatter": {
		"formatWithErrors": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"arrowParentheses": "asNeeded",
			"lineWidth": 100
		}
	},
	"json": {
		"formatter": {
			"enabled": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": false,
			"a11y": {
				"noAccessKey": "error",
				"noAriaHiddenOnFocusable": "error",
				"noAriaUnsupportedElements": "error",
				"noHeaderScope": "error",
				"noInteractiveElementToNoninteractiveRole": "error",
				"noNoninteractiveElementToInteractiveRole": "error",
				"noNoninteractiveTabindex": "error",
				"noPositiveTabindex": "error",
				"noSvgWithoutTitle": "error",
				"useAltText": "error",
				"useAriaPropsForRole": "error",
				"useButtonType": "error",
				"useHtmlLang": "error",
				"useKeyWithClickEvents": "error",
				"useKeyWithMouseEvents": "error",
				"useValidAriaProps": "error",
				"useValidLang": "error"
			},
			"complexity": {
				"noBannedTypes": "error",
				"noExtraBooleanCast": "warn",
				"noForEach": "warn",
				"noThisInStatic": "warn",
				"noUselessEmptyExport": "warn",
				"noUselessFragments": "warn",
				"noUselessRename": "warn",
				"noUselessSwitchCase": "warn",
				"noUselessTypeConstraint": "warn",
				"noUselessTernary": "warn",
				"useArrowFunction": "warn",
				"useFlatMap": "warn",
				"useLiteralKeys": "warn",
				"useOptionalChain": "warn",
				"noArguments": "error"
			},
			"correctness": {
				"noChildrenProp": "warn",
				"noInnerDeclarations": "error",
				"noPrecisionLoss": "error",
				"noSelfAssign": "warn",
				"noStringCaseMismatch": "error",
				"noSwitchDeclarations": "error",
				"noUnreachable": "warn",
				"noUnsafeFinally": "error",
				"noUnsafeOptionalChaining": "error",
				"noUnusedLabels": "warn",
				"noVoidElementsWithChildren": "error",
				"useJsxKeyInIterable": "error",
				"useValidForDirection": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error"
			},
			"security": {
				"noDangerouslySetInnerHtml": "error",
				"noDangerouslySetInnerHtmlWithChildren": "error",
				"noGlobalEval": "error",
				"noBlankTarget": "error"
			},
			"style": {
				"noInferrableTypes": "warn",
				"noNegationElse": "warn",
				"noNonNullAssertion": "warn",
				"noRestrictedGlobals": "error",
				"noUnusedTemplateLiteral": "warn",
				"noUselessElse": "warn",
				"useAsConstAssertion": "warn",
				"useBlockStatements": "warn",
				"useCollapsedElseIf": "warn",
				"useConst": "warn",
				"useDefaultParameterLast": "warn",
				"useEnumInitializers": "error",
				"useExportType": "error",
				"useFilenamingConvention": "warn",
				"useFragmentSyntax": "warn",
				"useLiteralEnumMembers": "error",
				"useNumberNamespace": "warn",
				"useSelfClosingElements": "warn",
				"useShorthandAssign": "warn",
				"useConsistentArrayType": { "level": "warn", "options": { "syntax": "shorthand" } }
			},
			"suspicious": {
				"noArrayIndexKey": "error",
				"noAsyncPromiseExecutor": "error",
				"useAwait": "warn",
				"noCommentText": "error",
				"noConstEnum": "error",
				"noDebugger": "warn",
				"noDoubleEquals": "error",
				"noEmptyInterface": "warn",
				"noExplicitAny": "error",
				"noExtraNonNullAssertion": "warn",
				"noFallthroughSwitchClause": "error",
				"noGlobalIsFinite": "error",
				"noGlobalIsNan": "error",
				"noImplicitAnyLet": "error",
				"noMisleadingInstantiator": "error",
				"noPrototypeBuiltins": "error",
				"noSparseArray": "error",
				"noSuspiciousSemicolonInJsx": "error",
				"noThenProperty": "error",
				"noUnsafeNegation": "error",
				"useDefaultSwitchClauseLast": "warn",
				"useNamespaceKeyword": "warn",
				"noVar": "error",
				"noConsole": { "level": "warn", "options": { "allow": ["log"] } }
			},
			"nursery": {
				"useSortedClasses": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/components/**/*/index.tsx"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "warn"
					}
				}
			}
		},
		{
			"includes": ["**/utils/**", "**/packages/publish-extension/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": { "level": "off", "options": { "allow": ["log"] } }
					}
				}
			}
		}
	]
}
